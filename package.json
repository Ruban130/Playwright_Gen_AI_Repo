{
  "name": "playwright-automation-framework",
  "version": "1.0.0",
  "description": "Enterprise-grade Playwright automation framework with Page Object Model, API testing, and comprehensive reporting",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:report": "allure generate --clean -o allure-report && allure open",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "docker:build": "docker build -t playwright-automation:latest .",
    "docker:run": "docker run --rm playwright-automation:latest",
    "clean": "rm -rf test-results allure-results allure-report"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "e2e",
    "api-testing",
    "page-object-model"
  ],
  "author": "SDET Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "allure-playwright": "^2.11.0",
    "dotenv": "^16.3.1",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "@faker-js/faker": "^8.3.1",
    "axios": "^1.6.2",
    "winston": "^3.11.0"
  }
}
